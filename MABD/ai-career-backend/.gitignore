# CRITICAL: Never commit secrets
.env
.env.*

# Local SQLite database
*.db
*.db-journal
*.sqlite3

# Python virtual environment
venv/
ENV/
env/
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# Django
staticfiles/
media/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Railway / Docker build artifacts
.nixpacks/
